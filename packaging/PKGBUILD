# Maintainer: Rushikesh Sakharle <ramsharath@instantly.ai>
pkgname=ps_mem
pkgver=1.0.3
pkgrel=1
pkgdesc="C port of ps_mem with smaps_rollup optimization"
arch=('x86_64' 'aarch64')
url="https://github.com/rushikeshsakharleofficial/ps_mem-c"
license=('LGPL2')
makedepends=('gcc')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "ps_mem-c-${pkgver}"
    gcc -O2 -o ps_mem ps_mem.c
}

package() {
    cd "ps_mem-c-${pkgver}"
    install -Dm755 ps_mem "${pkgdir}/usr/bin/ps_mem"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    install -Dm644 ps_mem.py "${pkgdir}/usr/share/doc/${pkgname}/ps_mem.py"
}
